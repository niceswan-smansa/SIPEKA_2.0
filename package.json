{
  "name": "sipeka",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "node tools/run-local-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:db": "supabase test db",
    "test:e2e": "playwright test",
    "test:e2e:reset": "node tools/run-destructive-e2e.mjs",
    "test:bundle": "node tools/assert-no-service-key-in-client.mjs",
    "test:assets": "node tools/assert-assets.mjs",
    "test:pwa": "node tools/assert-pwa.mjs",
    "migration:dry-run": "node tools/student-migration-dry-run.mjs --source data_siswa",
    "migration:real-local": "node tools/student-real-local-bootstrap.mjs",
    "migration:real-local:apply": "node tools/student-real-local-bootstrap.mjs --apply",
    "smoke:production": "node tools/production-smoke.mjs",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:types": "node tools/generate-database-types.mjs",
    "db:types:check": "node tools/generate-database-types.mjs --check",
    "seed:test-users": "node tools/provision-test-users.mjs",
    "seed:initial-local-accounts": "node tools/provision-initial-local-accounts.mjs",
    "test:auth-probe": "node tools/probe-test-auth.mjs",
    "test:auth-policy": "node tools/assert-username-auth-policy.mjs",
    "bootstrap:super-admin": "node tools/bootstrap-super-admin.mjs",
    "check": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "0.10.0",
    "@supabase/supabase-js": "2.109.0",
    "exceljs": "^4.4.0",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "recharts": "^3.10.0",
    "server-only": "0.0.1",
    "ws": "8.21.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "prettier": "3.9.6",
    "supabase": "2.109.1",
    "tailwindcss": "^4.3.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
