# Placeholder values only. Never commit real credentials.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=local-placeholder-publishable-key
SUPABASE_SERVICE_ROLE_KEY=local-placeholder-service-role-key
APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Jakarta
RATE_LIMIT_SECRET=replace-with-a-local-secret

# Optional local/server-only administration. Never expose these to the browser.
BOOTSTRAP_SUPER_ADMIN_EMAIL=replace-with-local-email
BOOTSTRAP_SUPER_ADMIN_USERNAME=replace-with-local-username
BOOTSTRAP_SUPER_ADMIN_FULL_NAME=replace-with-local-name
BOOTSTRAP_SUPER_ADMIN_PASSWORD=replace-with-a-strong-local-password
ALLOW_REMOTE_SUPER_ADMIN_BOOTSTRAP=false
